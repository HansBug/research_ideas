@startuml
!pragma layout smetana

skinparam backgroundColor #FFFFFF
skinparam defaultFontName 微软雅黑

rectangle "输入层" as input_group {
  card "控制系统软件需求文档" as ReqDoc #FFD2B4
  card "状态机模型\n(来自研究内容一)" as StateMachineModel #B4D8FF
  card "领域知识库\n(标准、协议、设计规范等)" as DomainKnowledge #D2B4FF
}

package "大语言模型 (LLM) 处理引擎" as llm_engine {
  usecase "1. 语义解析与\n关键信息提取" as SemanticParsing #MintCream
  usecase "2. 验证场景剖面生成" as ScenarioGen #MintCream
  usecase "3. 形式化性质生成" as PropertyGen #MintCream
}

SemanticParsing --> ScenarioGen
SemanticParsing --> PropertyGen

rectangle "输出层" as output_group {
  card "验证场景剖面" as ScenarioProfile #FFB4DA
  card "形式化性质规约" as FormalProperties #B4FFDA
}

rectangle "人工评估反馈（非必须）" as Feedback #LightGrey

ReqDoc --> SemanticParsing
StateMachineModel --> SemanticParsing
DomainKnowledge --> SemanticParsing

ScenarioGen --> ScenarioProfile
PropertyGen --> FormalProperties

ScenarioProfile ..> Feedback
FormalProperties ..> Feedback
Feedback ..> SemanticParsing
@enduml