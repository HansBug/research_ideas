@startuml
!pragma layout smetana
skinparam backgroundColor #FFFFFF
skinparam defaultFontName 微软雅黑

actor "控制系统设计者" as Designer #4B0082
rectangle "LLM辅助建模系统" {
  usecase "需求解析与元素识别\n(时间约束、并发、同步)" as Parse #FFD2B4
  usecase "状态机结构构建\n(状态、迁移、守卫条件)" as BuildStructure #B4D8FF
  usecase "动作与时间属性关联\n(变量赋值、外部控制、时间语义)" as AddActions #D2B4FF
  usecase "模型输出与形式化表示\n(SCXML、语法检查)" as OutputModel #B4FFDA
  
  Designer --> Parse : 自然语言需求 (R)
  Parse --> BuildStructure : 识别元素 (S, E, V)
  BuildStructure --> AddActions : 初步结构 (S, Tr)
  AddActions --> OutputModel : 完整模型 (M)
  OutputModel --> Designer : 形式化状态机模型 (M)
  
  note right of Parse
    提取时间约束
    识别并发与同步需求
    识别状态、事件、变量
  end note
  note right of BuildStructure
    构建状态层次结构
    定义迁移路径
    引入守卫条件 (Gc)
  end note
  note right of AddActions
    关联进入/退出动作 (Aentry, Aexit)
    关联迁移动作 (Atrans)
    引入时间属性 (Tmin, Tmax)
  end note
  note right of OutputModel
    生成SCXML/其他DSL
    语法与结构验证
  end note
}
@enduml