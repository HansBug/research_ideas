@article{bhamare_cybersecurity_2020,
	title = {Cybersecurity for industrial control systems: {A} survey},
	volume = {89},
	issn = {0167-4048},
	shorttitle = {Cybersecurity for industrial control systems},
	url = {https://www.sciencedirect.com/science/article/pii/S0167404819302172},
	doi = {10.1016/j.cose.2019.101677},
	abstract = {Industrial Control System (ICS) is a general term that includes supervisory control \& data acquisition (SCADA) systems, distributed control systems (DCS), and other control system configurations such as programmable logic controllers (PLC). ICSs are often found in the industrial sectors and critical infrastructures, such as nuclear and thermal plants, water treatment facilities, power generation, heavy industries, and distribution systems. Though ICSs were kept isolated from the Internet for so long, significant achievable business benefits are driving a convergence between ICSs and the Internet as well as information technology (IT) environments, such as cloud computing. As a result, ICSs have been exposed to the attack vectors used in the majority of cyber-attacks. However, ICS devices are inherently much less secure against such advanced attack scenarios. A compromise to ICS can lead to enormous physical damage and danger to human lives. In this work, we have a close look at the shift of the ICS from stand-alone systems to cloud-based environments. Then we discuss the major works, from industry and academia towards the development of the secure ICSs, especially applicability of the machine learning techniques for the ICS cyber-security. The work may help to address the challenges of securing industrial processes, particularly while migrating them to the cloud environments.},
	language = {en-US},
	urldate = {2025-08-05},
	journal = {Computers \& Security},
	author = {Bhamare, Deval and Zolanvari, Maede and Erbad, Aiman and Jain, Raj and Khan, Khaled and Meskin, Nader},
	month = feb,
	year = {2020},
	note = {titleTranslation: 工业控制系统网络安全：综述},
	keywords = {Cloud computing, Cybersecurity, Industrial control system, Intrusion detection system, Machine learning},
	pages = {101677},
	file = {ScienceDirect Full Text PDF:/home/hansbug/Zotero/storage/XVVUKMNJ/Bhamare 等 - 2020 - Cybersecurity for industrial control systems A survey.pdf:application/pdf;ScienceDirect Snapshot:/home/hansbug/Zotero/storage/7BIQU2W7/S0167404819302172.html:text/html},
}


@article{knowles_survey_2015,
	title = {A survey of cyber security management in industrial control systems},
	volume = {9},
	issn = {1874-5482},
	url = {https://www.sciencedirect.com/science/article/pii/S1874548215000207},
	doi = {10.1016/j.ijcip.2015.02.002},
	abstract = {Contemporary industrial control systems no longer operate in isolation, but use other networks (e.g., corporate networks and the Internet) to facilitate and improve business processes. The consequence of this development is the increased exposure to cyber threats. This paper surveys the latest methodologies and research for measuring and managing this risk. A dearth of industrial-control-system-specific security metrics has been identified as a barrier to implementing these methodologies. Consequently, an agenda for future research on industrial control system security metrics is outlined. The “functional assurance” concept is also introduced to deal with fail-safe and fail-secure industrial control system operations.},
	language = {en-US},
	urldate = {2025-08-05},
	journal = {International Journal of Critical Infrastructure Protection},
	author = {Knowles, William and Prince, Daniel and Hutchison, David and Disso, Jules Ferdinand Pagna and Jones, Kevin},
	month = jun,
	year = {2015},
	note = {titleTranslation: 工业控制系统中的网络安全管理综述
abstractTranslation: 现代工业控制系统已不再孤立运行，而是通过其他网络（如企业网络和互联网）来优化业务流程。这一发展趋势导致系统面临更多网络威胁。本文综述了当前测量与管理此类风险的最新方法及研究进展，指出工业控制系统专用安全指标的匮乏是实施这些方法的主要障碍。为此，本文提出了未来工业控制系统安全指标的研究方向，并引入"功能保障"概念以应对故障安全与故障保护型工业控制系统的运行需求。},
	keywords = {Industrial control systems, Risk assessment, Risk management, Risk metrics, SCADA systems, Security metrics},
	pages = {52--80},
	file = {ScienceDirect Full Text PDF:/home/hansbug/Zotero/storage/C3DS3SCW/Knowles 等 - 2015 - A survey of cyber security management in industrial control systems.pdf:application/pdf;ScienceDirect Snapshot:/home/hansbug/Zotero/storage/X5CTVTKP/S1874548215000207.html:text/html},
}

