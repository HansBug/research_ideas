	note = {titleTranslation: 大型语言模型：其发展、能力与应用综述},
	keywords = {Applied Linguistics, Computational Linguistics, Generative AI, Language History, Language Teaching and Learning, Large language models, Linear Models and Regression, Natural language processing, Neural networks, Research Methods in Language and Linguistics},
	pages = {2967--3022},
	file = {Full Text PDF:/home/hansbug/Zotero/storage/RH6ZF35I/Annepaka和Pakray - 2025 - Large language models a survey of their development, capabilities, and applications.pdf:application/pdf},
}



