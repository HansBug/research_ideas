@misc{sami_tool_2024,
	title = {A {Tool} for {Test} {Case} {Scenarios} {Generation} {Using} {Large} {Language} {Models}},
	url = {http://arxiv.org/abs/2406.07021},
	doi = {10.48550/arXiv.2406.07021},
	abstract = {Large Language Models (LLMs) are widely used in Software Engineering (SE) for various tasks, including generating code, designing and documenting software, adding code comments, reviewing code, and writing test scripts. However, creating test scripts or automating test cases demands test suite documentation that comprehensively covers functional requirements. Such documentation must enable thorough testing within a constrained scope and timeframe, particularly as requirements and user demands evolve. This article centers on generating user requirements as epics and high-level user stories and crafting test case scenarios based on these stories. It introduces a web-based software tool that employs an LLM-based agent and prompt engineering to automate the generation of test case scenarios against user requirements.},
	language = {en-US},
	urldate = {2025-08-05},
	publisher = {arXiv},
	author = {Sami, Abdul Malik and Rasheed, Zeeshan and Waseem, Muhammad and Zhang, Zheying and Tomas, Herda and Abrahamsson, Pekka},
	month = jun,
	year = {2024},
	note = {arXiv:2406.07021 [cs]
titleTranslation: 利用大型语言模型生成测试案例场景的工具
abstractTranslation: 大型语言模型（LLM）在软件工程（SE）领域被广泛应用于多种任务，包括代码生成、软件设计与文档编写、添加代码注释、代码审查以及测试脚本撰写。然而，创建测试脚本或自动化测试用例需要测试套件文档能够全面覆盖功能需求。此类文档必须确保在有限范围和时间内实现充分测试，尤其当需求与用户诉求持续演变时。本文聚焦于将用户需求生成史诗级主题与高层用户故事，并基于这些故事构建测试场景用例。文章介绍了一款基于网络的软件工具，该工具通过LLM驱动智能体与提示词工程，实现了针对用户需求的测试场景用例自动化生成。},
	keywords = {Computer Science - Software Engineering},
	file = {Preprint PDF:/home/hansbug/Zotero/storage/J69QI6GQ/Sami 等 - 2024 - A Tool for Test Case Scenarios Generation Using Large Language Models.pdf:application/pdf;Snapshot:/home/hansbug/Zotero/storage/VTIJA8EY/2406.html:text/html},
}



@phdthesis{de_bari_evaluating_2024,
	type = {laurea},
	title = {Evaluating {Large} {Language} {Models} in {Software} {Design}: {A} {Comparative} {Analysis} of {UML} {Class} {Diagram} {Generation}},
	copyright = {cc\_by\_nc\_nd},
	shorttitle = {Evaluating {Large} {Language} {Models} in {Software} {Design}},
	url = {https://webthesis.biblio.polito.it/31177/},
	abstract = {This master’s thesis aims to assess the feasibility of utilizing Large Language Models (LLMs) to generate Unified Modeling Language (UML) Class Diagrams. UML is a standardized visual language widely used in software engineering to depict the structure and design of a software system, enabling clear communication and documentation of system components and their relationships.  By comparing the LLM-generated diagrams with those produced by humans, particularly during the crucial initial phase of requirement gathering, the research assesses whether AI can support or enhance traditional software modeling practices. The study utilizes a two-part methodology complemented by a statistical analysis. In the first part, the diagrams are examined for syntactic (adherence to UML rules), semantic  (accuracy of meaning and concepts), and pragmatic (usefulness and applicability) quality errors, in the second part the semantic distance between the generated diagrams and the given solutions is calculated by using a specific algorithm.    The findings suggest that LLMs are capable of generating UML class diagrams with a level of syntactic and pragmatic quality comparable to that of human-produced diagrams, due to no statistically significant differences in these areas. However, the analysis also uncovers a noticeable gap in semantic quality, where human-generated diagrams outperform those generated by LLMs, highlighting the current limitation of LLMs in understanding the semantic nuances required to generate an accurate diagram.    Moreover, the study finds that LLM-produced diagrams are typically more distant from the reference solution, emphasizing the challenges that LLMs face in domain-specific knowledge that human experts are able to bring in the creation of the diagram.    With those findings the thesis contributes to the ongoing discussion on the role of AI in software engineering, showing that, while LLMs show promise in certain aspects of UML class diagram generation, there is a gap in semantic accuracy, underlining the necessity of further advancements in AI capabilities to reach the same quality level of human-generated diagrams.},
	language = {it},
	urldate = {2025-08-06},
	school = {Politecnico di Torino},
	author = {De Bari, Daniele},
	month = apr,
	year = {2024},
	note = {titleTranslation: 评估大型语言模型在软件设计中的表现：UML类图生成的对比分析
abstractTranslation: 本硕士论文旨在评估利用大型语言模型（LLM）生成统一建模语言（UML）类图的可行性。UML作为一种标准化可视化语言，广泛应用于软件工程领域，用于描述软件系统的结构与设计，从而清晰传达系统组件及其相互关系。  
研究通过对比LLM生成的类图与人工绘制的类图（尤其在需求收集的关键初始阶段），评估人工智能是否能够支持或增强传统软件建模实践。该研究采用包含统计分析的二阶段方法：第一阶段从语法（遵循UML规则）、语义（概念与含义的准确性）和语用（实用性与适用性）三个维度检测类图质量缺陷；第二阶段通过特定算法计算生成类图与给定参考答案之间的语义距离。  
研究结果表明，由于在这些维度上未发现统计学显著差异，LLM生成的UML类图在语法和语用质量方面可与人工绘制的类图相媲美。然而分析同时揭示了语义质量存在明显差距——人工绘制的类图表现更优，这凸显了LLM当前在理解生成精确类图所需语义细节方面的局限性。  
此外，研究发现LLM生成的类图通常与参考解决方案的偏差更大，这强调了LLM在领域专业知识方面面临的挑战，而人类专家在绘制过程中能有效融入此类知识。  
基于这些发现，本论文为人工智能在软件工程中作用的持续讨论提供了新见解：尽管LLM在UML类图生成的某些方面展现出潜力，但其语义准确性仍存在差距，这凸显了需进一步提升AI能力才能达到人类绘制类图的同等质量水平。},
	file = {Full Text PDF:/home/hansbug/Zotero/storage/HLD67ZG3/De Bari - 2024 - Evaluating Large Language Models in Software Design A Comparative Analysis of UML Class Diagram Gen.pdf:application/pdf;Snapshot:/home/hansbug/Zotero/storage/9HWMJNWJ/31177.html:text/html},
}

@inproceedings{shehata_creating_2024,
	title = {Creating {UML} {Class} {Diagrams} with {General}-{Purpose} {LLMs}},
	url = {https://ieeexplore.ieee.org/abstract/document/10794946},
	doi = {10.1109/VISSOFT64034.2024.00031},
	abstract = {General-purpose large language models (LLMs) have become a versatile tool in software development and maintenance. These models offer support in tasks such as under-standing, writing, and summarizing code. While these LLMs can generate code quickly their use in software modeling is relatively under-explored. This research aims to study ChatGPT's ability to generate class diagrams from source code. To do this, we engineered a prompt that takes in source code to create a UML class diagram for that system. We used this prompt to create class diagrams for 40 systems and assessed the diagrams on their correctness and structure. Our results show that ChatGPT creates class diagrams that accurately capture 90\% of the classes and their attributes and 66 \% of the associations. While ChatGPT performed nearly flawlessly for smaller projects, the diagrams for larger projects had more issues. We conclude that ChatGPT is best utilized as a complementary tool rather than the sole resource for software modeling and maintenance.},
	language = {en-US},
	urldate = {2025-08-06},
	booktitle = {2024 {IEEE} {Working} {Conference} on {Software} {Visualization} ({VISSOFT})},
	author = {Shehata, Mina and Lepore, Blaire and Cummings, Hailey and Parra, Esteban},
	month = oct,
	year = {2024},
	note = {ISSN: 2832-6555
titleTranslation: 使用通用大语言模型创建UML类图
abstractTranslation: 通用型大语言模型（LLM）已成为软件开发和维护中的多功能工具。这些模型在代码理解、编写和总结等任务中提供支持。尽管LLM能快速生成代码，但其在软件建模中的应用仍相对缺乏探索。本研究旨在探究ChatGPT从源代码生成类图的能力。为此，我们设计了一个提示模板，通过输入源代码来生成对应系统的UML类图。使用该模板为40个系统创建类图后，我们从准确性和结构完整性两方面进行评估。结果表明：ChatGPT生成的类图能准确捕捉90\%的类及其属性，以及66\%的关联关系。虽然ChatGPT在小型项目中表现近乎完美，但针对大型项目的图表存在较多问题。我们得出结论：ChatGPT最适合作为软件建模和维护的辅助工具，而非唯一资源。},
	keywords = {—UML, Chatbots, ChatGPT, class diagrams, Codes, Large Language Models, LLM, Maintenance, open source, Scalability, Software development management, software maintenance, Software systems, Source coding, Unified modeling language, Visualization, Writing},
	pages = {157--158},
	file = {Full Text PDF:/home/hansbug/Zotero/storage/HUPIXBSR/Shehata 等 - 2024 - Creating UML Class Diagrams with General-Purpose LLMs.pdf:application/pdf},
}

@inproceedings{ferrari_model_2024,
	title = {Model {Generation} with {LLMs}: {From} {Requirements} to {UML} {Sequence} {Diagrams}},
	shorttitle = {Model {Generation} with {LLMs}},
	url = {https://ieeexplore.ieee.org/abstract/document/10628665},
	doi = {10.1109/REW61692.2024.00044},
	abstract = {Complementing natural language (NL) requirements with graphical models can improve stakeholders' communication and provide directions for system design. However, creating models from requirements involves manual effort. The advent of generative large language models (LLMs), ChatGPT being a notable example, offers promising avenues for automated assistance in model generation. This paper investigates the capability of ChatGPT to generate a specific type of model, i.e., UML sequence diagrams, from NL requirements. We conduct a qualitative study in which we examine the sequence diagrams generated by ChatGPT for 28 requirements documents of various types and from different domains. Observations from the analysis of the generated diagrams have systematically been captured through evaluation logs, and categorized through thematic analysis. Our results indicate that, although the models generally conform to the standard and exhibit a reasonable level of understandability, their completeness and correctness with respect to the specified requirements often present challenges. This issue is particularly pronounced in the presence of requirements smells, such as ambiguity and inconsistency. The insights derived from this study can influence the practical utilization of LLMs in the RE process, and open the door to novel RE-specific prompting strategies targeting effective model generation.},
	language = {en-US},
	urldate = {2025-08-06},
	booktitle = {2024 {IEEE} 32nd {International} {Requirements} {Engineering} {Conference} {Workshops} ({REW})},
	author = {Ferrari, Alessio and Abualhaija, Sallam and Arora, Chetan},
	month = jun,
	year = {2024},
	note = {ISSN: 2770-6834
titleTranslation: 基于大语言模型的模型生成：从需求到UML序列图
abstractTranslation: 在自然语言（NL）需求基础上辅以图形化模型，可提升利益相关方之间的沟通效率，并为系统设计提供方向指引。然而，从需求文本手动构建模型需要消耗大量人力。以ChatGPT为代表的生成式大语言模型（LLMs）的出现，为自动化辅助模型生成提供了新途径。本文研究了ChatGPT从NL需求生成特定类型模型（即UML顺序图）的能力。我们通过定性研究，对ChatGPT针对28份跨领域多类型需求文档生成的顺序图进行系统性检验。通过评估日志记录生成图的分析观察结果，并采用主题分析法进行分类。研究结果表明：尽管生成模型总体上符合标准且具有可理解性，但其相对于需求规范的完整性和正确性仍存在不足，尤其在需求异味（如歧义性和不一致性）存在时更为显著。本研究获得的见解可影响LLMs在需求工程（RE）实践中的应用，并为开发针对高效模型生成的新型RE提示策略开辟道路。},
	keywords = {Chatbots, ChatGPT, Context modeling, Large language models, Large Language Models (LLMs), Manuals, Model Generation, Natural Language Processing (NLP), Prompt Engineering, Reliability, Requirements engineering, Sequence Diagrams, Stakeholders, Standards, System analysis and design, Unified modeling language},
	pages = {291--300},
	file = {Full Text PDF:/home/hansbug/Zotero/storage/ZTQS99DU/Ferrari 等 - 2024 - Model Generation with LLMs From Requirements to UML Sequence Diagrams.pdf:application/pdf},
}

@article{camara_assessment_2023,
	title = {On the assessment of generative {AI} in modeling tasks: an experience report with {ChatGPT} and {UML}},
	volume = {22},
	issn = {1619-1374},
	shorttitle = {On the assessment of generative {AI} in modeling tasks},
	url = {https://doi.org/10.1007/s10270-023-01105-5},
	doi = {10.1007/s10270-023-01105-5},
	abstract = {Most experts agree that large language models (LLMs), such as those used by Copilot and ChatGPT, are expected to revolutionize the way in which software is developed. Many papers are currently devoted to analyzing the potential advantages and limitations of these generative AI models for writing code. However, the analysis of the current state of LLMs with respect to software modeling has received little attention. In this paper, we investigate the current capabilities of ChatGPT to perform modeling tasks and to assist modelers, while also trying to identify its main shortcomings. Our findings show that, in contrast to code generation, the performance of the current version of ChatGPT for software modeling is limited, with various syntactic and semantic deficiencies, lack of consistency in responses and scalability issues. We also outline our views on how we perceive the role that LLMs can play in the software modeling discipline in the short term, and how the modeling community can help to improve the current capabilities of ChatGPT and the coming LLMs for software modeling.},
	language = {en},
	number = {3},
	urldate = {2025-08-06},
	journal = {Software and Systems Modeling},
	author = {Cámara, Javier and Troya, Javier and Burgueño, Lola and Vallecillo, Antonio},
	month = jun,
	year = {2023},
	note = {titleTranslation: 关于生成式AI在建模任务中的评估：ChatGPT与UML的实践报告
abstractTranslation: 大多数学者认为，Copilot和ChatGPT所采用的大型语言模型（LLMs）将彻底改变软件开发方式。目前已有大量论文致力于分析这类生成式AI模型在代码编写领域的潜在优势与局限。然而，关于LLMs在软件建模领域现状的研究却鲜有关注。本文系统考察了ChatGPT执行建模任务及辅助建模工作者的现有能力，同时试图识别其主要缺陷。研究发现：与代码生成相比，当前版本的ChatGPT在软件建模方面表现有限，存在语法与语义缺陷、响应不一致及可扩展性问题。我们还就LLMs短期内如何在软件建模学科发挥作用，以及建模界如何助力提升ChatGPT及后续LLMs的建模能力，阐述了前瞻性见解。},
	keywords = {Artificial Intelligence, ChatGPT, Computational Intelligence, Computational Linguistics, Computer Modelling, Formal Languages and Automata Theory, Information Model, Large language models, Modeling languages, Software models, UML},
	pages = {781--793},
	file = {Full Text PDF:/home/hansbug/Zotero/storage/9FGRS4JE/Cámara 等 - 2023 - On the assessment of generative AI in modeling tasks an experience report with ChatGPT and UML.pdf:application/pdf},
}




@article{park_case_2024,
	title = {A case study to address the limitation of accident scenario identifications with respect to diverse manual responses},
	volume = {251},
	issn = {0951-8320},
	url = {https://www.sciencedirect.com/science/article/pii/S0951832024004782},
	doi = {10.1016/j.ress.2024.110406},
	abstract = {Probabilistic safety assessment (PSA) is a tool for securing the operational safety of nuclear power plants. One unique benefit of PSA is to identify accident scenarios leading to undesirable consequences. Since these accident scenarios result from highly complicated combinations of automatic and manual responses, a huge number of simulations are generally required with a precise thermal-hydraulic (TH) code. Therefore, current PSA typically reduces the number of TH code runs by focusing on limited numbers of safety-critical components with reasonable engineering assumptions. Nevertheless, it has been pointed out that the current catalog of accident scenarios in PSA may be insufficient to some extent. In order to corroborate this claim, in this work, 14,348,907 simulation conditions were randomly generated after combining 79 manual responses identified from the emergency operating procedure of a steam generator tube rupture (SGTR) event in a reference nuclear power plant. Results show that about 14.7 \% of the simulations correspond to an undesirable consequence pertaining to the SGTR. Accordingly, in terms of enhancing the quality of PSA results, the results of this study support that it is inevitable to develop a promising way to reduce the amount of computational resources required by large numbers of TH code runs.},
	language = {en-US},
	urldate = {2025-08-06},
	journal = {Reliability Engineering \& System Safety},
	author = {Park, Jinkyun and Kim, Hyeonmin},
	month = nov,
	year = {2024},
	note = {titleTranslation: 针对多样化人工响应中事故情景识别局限性的案例研究
abstractTranslation: 概率安全评估（PSA）是保障核电厂运行安全的工具，其独特优势在于能识别导致不良后果的事故情景。由于这些事故情景源于自动与手动响应的复杂组合，通常需要借助精确的热工水力（TH）程序进行大量模拟。因此，当前PSA通常通过聚焦有限数量的安全关键部件并采用合理工程假设，以减少TH程序运行次数。然而有研究指出，现有PSA的事故情景清单可能存在不足。为验证该观点，本研究结合参考核电厂蒸汽发生器传热管破裂（SGTR）事件应急操作规程中的79项手动响应措施，随机生成了14,348,907种模拟工况。结果表明约14.7\%的模拟工况会导致与SGTR相关的不良后果。由此可见，为提高PSA结果质量，必须开发能减少大量TH程序运行所需计算资源的新方法。},
	keywords = {Accident scenario progression, Manual response, Nuclear power plant, Probabilistic safety assessment, Stochastic behavior},
	pages = {110406},
	file = {ScienceDirect Full Text PDF:/home/hansbug/Zotero/storage/SMQN32DH/Park和Kim - 2024 - A case study to address the limitation of accident scenario identifications with respect to diverse.pdf:application/pdf;ScienceDirect Snapshot:/home/hansbug/Zotero/storage/BC4CCSQB/S0951832024004782.html:text/html},
}

@misc{wei_unleashing_2025,
