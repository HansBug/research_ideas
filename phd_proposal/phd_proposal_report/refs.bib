@article{stavrianidis_reliability_1993,
	title = {Reliability and uncertainty analysis of hardware failures of a programmable electronic system},
	volume = {39},
	issn = {0951-8320},
	url = {https://www.sciencedirect.com/science/article/pii/095183209390006K},
	doi = {10.1016/0951-8320(93)90006-K},
	abstract = {This paper presents a methodology for evaluating the performance of Programmable Electronic Systems (PES) used for safety applications. The most common PESs used in the industry are identified. Markov modeling techniques are used to develop the reliability model. The major aspects of the analysis address the random hardware failures, the uncertainty associated with these failures, a methodology to propagate these uncertainties in the Markov model, and modeling of common cause failures. The elements of this methodology are applied to an example using a Triple Redundant PES without inter-processor communication. The performance of the PES is quantified in terms of its reliability, probability to fail safe, and probability to fail dangerous within a mission time. The effect of model input parameters (component failure rates, diagnostic coverage), their uncertainties and common cause failures on the performance of the PES is evaluated.},
	language = {en-US},
	number = {3},
	urldate = {2025-08-05},
	journal = {Reliability Engineering \& System Safety},
	author = {Stavrianidis, Paraskevas},
	month = jan,
	year = {1993},
	note = {titleTranslation: 可编程电子系统硬件故障的可靠性与不确定性分析
abstractTranslation: 本文提出了一种用于评估安全应用中可编程电子系统(PES)性能的方法论。研究首先明确了工业领域最常用的PES类型，继而采用马尔可夫建模技术构建可靠性模型。该分析主要涉及随机硬件故障、相关故障的不确定性、马尔可夫模型中不确定性传递的方法论，以及共因故障建模。通过三重冗余无处理器间通信的PES实例验证了该方法论要素。研究从可靠性、安全失效概率及任务周期内危险失效概率三个维度量化PES性能，并评估了模型输入参数（元件失效率、诊断覆盖率）、参数不确定性及共因故障对系统性能的影响。},
	pages = {309--324},
	file = {ScienceDirect Snapshot:/home/hansbug/Zotero/storage/FRLUWWM4/095183209390006K.html:text/html},
}

@inproceedings{gorecky_human-machine-interaction_2014,
	title = {Human-machine-interaction in the industry 4.0 era},
	url = {https://ieeexplore.ieee.org/abstract/document/6945523},
	doi = {10.1109/INDIN.2014.6945523},
	abstract = {The development of Industry 4.0 will be accompanied by changing tasks and demands for the human in the factory. As the most flexible entity in cyber-physical production systems, workers will be faced with a large variety of jobs ranging from specification and monitoring to verification of production strategies. Through technological support it is guaranteed that workers can realize their full potential and adopt the role of strategic decision-makers and flexible problem-solvers. The use of established interaction technologies and metaphors from the consumer goods market seems to be promising. This paper demonstrates solutions for the technological assistance of workers, which implement the representation of a cyber-physical world and the therein occurring interactions in the form of intelligent user interfaces. Besides technological means, the paper points out the requirement for adequate qualification strategies, which will create the required, inter-disciplinary understanding for Industry 4.0.},
	language = {en-US},
	urldate = {2025-08-05},
	booktitle = {2014 12th {IEEE} {International} {Conference} on {Industrial} {Informatics} ({INDIN})},
	author = {Gorecky, Dominic and Schmitt, Mathias and Loskyll, Matthias and Zühlke, Detlef},
	month = jul,
	year = {2014},
	note = {ISSN: 2378-363X
titleTranslation: 工业4.0时代的人机交互
abstractTranslation: 工业4.0的发展将伴随着工厂中人类工作任务与需求的变革。作为信息物理生产系统中最灵活的实体，工人将面临从生产策略制定、监控到验证等多样化工作。通过技术支撑，可确保工人充分发挥潜能，承担战略决策者与灵活问题解决者的角色。采用消费级市场中成熟的交互技术与交互隐喻具有显著优势。本文展示了面向工人的技术辅助解决方案，这些方案通过智能用户界面实现信息物理世界的表征及其交互过程。除技术手段外，本文还指出建立适当资格认证体系的必要性，这将为工业4.0培养所需的跨学科理解能力。},
	keywords = {Context, cyber-physical Systems, human-computer-interaction, Industries, Industry 4.0, Manufacturing, Mobile communication, Production facilities, User interfaces},
	pages = {289--294},
	file = {Full Text PDF:/home/hansbug/Zotero/storage/XYPPJVPX/Gorecky 等 - 2014 - Human-machine-interaction in the industry 4.0 era.pdf:application/pdf},
}


